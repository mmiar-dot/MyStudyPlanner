{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MyStudyPlanner",
  "version": "1.0.2",
  "identifier": "com.miaropiret.mystudyplanner",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "npx expo start --web",
    "beforeBuildCommand": "npx expo export"
  },
  "app": {
    "windows": [
      {
        "title": "frontendMyStudyPlanner",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Miaro Piret"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/MIAROPIRET/APPMYSTUDYPLANNER/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJFQkJCMTkyRjZBNzE4RkIKUldUN0dLZjJrckc3TGtJVGJJVElZeTZvU0tMaFdNTHo5RDROUUhjcGFESUJxQjJ2Mm1hOUtUNGYK"
    }
  }
}