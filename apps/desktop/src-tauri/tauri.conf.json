{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MyStudyPlanner",
  "version": "1.1.0",
  "identifier": "com.miaropiret.mystudyplanner",
  "build": {
    "frontendDist": "../../mobile/dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "cd ../mobile && npx expo start --web",
    "beforeBuildCommand": "cd ../mobile && npx expo export"
  },
  "app": {
    "windows": [
      {
        "title": "MyStudyPlanner",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "C9B735CE05D98FE81C8EB32FB246C8657C115B86",
      "entitlements": "./Entitlements.plist",
      "hardenedRuntime": true
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/mmiar-dot/MyStudyPlanner/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJFQkJCMTkyRjZBNzE4RkIKUldUN0dLZjJrckc3TGtJVGJJVElZeTZvU0tMaFdNTHo5RDROUUhjcGFESUJxQjJ2Mm1hOUtUNGYK"
    }
  }
}
