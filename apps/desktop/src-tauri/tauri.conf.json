{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MyStudyPlanner",
  "version": "1.2.3",
  "identifier": "com.miaropiret.mystudyplanner",
  "build": {
    "frontendDist": "../../mobile/dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "cd ../mobile && npx expo start --web --port 8081",
    "beforeBuildCommand": "cd ../mobile && npx expo export -p web"
  },
  "app": {
    "windows": [
      {
        "title": "MyStudyPlanner",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.13"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/mmiar-dot/MyStudyPlanner/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI0QzI2MUI2QTI2N0VGMUUKUldRZTcyZWl0bUhDdE1KQW5JSDJYZUpDdGRzYzJTOUM3MUs5ZGFuMHdVV21vYXdSZkVwVDMrVEUK"
    }
  }
}
